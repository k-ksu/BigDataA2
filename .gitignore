# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# =============================================================================
# Virtual environment  (created by app.sh at runtime inside the container)
# =============================================================================
app/.venv/
app/.venv.tar.gz

# =============================================================================
# Data files  (too large for git — download / generate at runtime)
# =============================================================================

# Raw parquet file — download separately before running the pipeline
app/data/parquet/

# Document .txt files — generated by prepare_data.py at runtime
app/data/*.txt

# Spark SQL warehouse — created automatically by Spark
app/spark-warehouse/

# =============================================================================
# HDFS volume data  (managed by Docker volumes, not part of source code)
# =============================================================================
hdfs/namenode/
hdfs/datanode/

# =============================================================================
# Logs
# =============================================================================
*.log
*.out
logs/

# =============================================================================
# IDE / OS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
